# --- Database (PostgreSQL) ---
# Local example: postgresql://postgres:postgres@localhost:5432/gag2?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- Auth.js / NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
# Canonical URL of the deployment (used in emails and auth callbacks)
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- Bootstrap admin (used by `npm run db:seed`) ---
ADMIN_EMAIL="you@example.com"
ADMIN_USERNAME="owner"
ADMIN_PASSWORD="change-me-strong-password"

# --- Email (SMTP). If unset in development, emails are printed to the server console. ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="GAG2 Giveaways <no-reply@example.com>"

# --- Cloudflare Turnstile CAPTCHA. If unset in development, the check is skipped. ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Vercel Cron protection ---
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-me"

# --- Discord login (optional). Create an app at https://discord.com/developers/applications
# Redirect URI: <NEXTAUTH_URL>/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# --- Roblox login (optional). Create an OAuth app at https://create.roblox.com/dashboard/credentials
# Scopes: openid, profile · Redirect URI: <NEXTAUTH_URL>/api/auth/callback/roblox
ROBLOX_CLIENT_ID=""
ROBLOX_CLIENT_SECRET=""
